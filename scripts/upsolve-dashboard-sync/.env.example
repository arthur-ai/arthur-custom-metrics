# Copy this file to .env and fill in your values.
# .env is loaded automatically by upsolve-dashboard-sync.py (requires: pip install python-dotenv)

UPSOLVE_SRC_HOST=http://upsolve-staging:5001
UPSOLVE_DST_HOST=http://upsolve-prod:5001
UPSOLVE_SRC_API_KEY=sk-staging-...
UPSOLVE_DST_API_KEY=sk-prod-...

# FILES_KEY — baked into the Upsolve Docker image (upsolve/upsolve-onprem).
# Extract with: docker inspect upsolve/upsolve-onprem:<version> --format='{{range .Config.Env}}{{println .}}{{end}}' | grep FILES_KEY
# UPSOLVE_FILES_KEY=<64-char-hex>

# Optional: path to a JSON file mapping friendly names → dashboard UUIDs
# UPSOLVE_DASHBOARD_MAP=dashboard-ids.json
